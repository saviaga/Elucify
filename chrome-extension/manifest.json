{
  "manifest_version": 3,
  "name": "Elucify",
  "version": "1.0.0",
  "description": "AI-powered analysis of arXiv papers — summaries, glossaries, FAQs and more, right on the abstract page.",
  "host_permissions": ["https://arxiv.org/*"],
  "content_scripts": [
    {
      "matches": ["https://arxiv.org/abs/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
